# Copy to .env and fill in. .env is gitignored — never commit real values.
# (On Coolify/Portainer/etc., set these in the UI instead of using a file.)

# Xtream API provider — base URL only, no path or query string.
IPTV_HOST=http://provider.example.com
IPTV_USERNAME=your-username
IPTV_PASSWORD=your-password

# Rebuild schedule.
REFRESH_HOURS=24
# A playlist request older than this (minutes) also triggers a rebuild.
RELOAD_REFRESH_MINUTES=15
# Max seconds a request waits for that rebuild before serving the last copy.
RELOAD_WAIT_SECONDS=8

# Require ?token=... on every request. Strongly recommended when the server
# is reachable from the internet — the playlist embeds your IPTV credentials.
#TOKEN=pick-a-long-random-string

# ts or m3u8
#STREAM_EXT=ts

# Category selection. Regions are the prefix before the provider's group
# separator; EXCLUDE_GROUPS/ONLY_GROUPS are exact category names.
#INCLUDE_REGIONS=US,VIP,UK,CA,AU,NZ,CAR,ALL
#EXCLUDE_GROUPS=CA ❖ QUEBEC,CAR ❖  CARAÏBES,VIP ❖ FIFA WC26 ES,VIP ❖ FIFA WC26 FR,VIP ❖ FIFA WC26 AR,VIP ❖ BEIN SPORTS TOD
#ONLY_GROUPS=CAR ❖ CARIBBEAN
