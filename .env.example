# Copy to .env and fill in. .env is gitignored — never commit real values.
# (On Coolify/Portainer/etc., set these in the UI instead of using a file.)

# --- required: your Xtream API provider (base URL only, no path/query) ---
IPTV_HOST=http://provider.example.com
IPTV_USERNAME=your-username
IPTV_PASSWORD=your-password

# Require ?token=... on every request except /status. Strongly recommended
# when the server is reachable from the internet — the playlist embeds your
# IPTV credentials.
#TOKEN=pick-a-long-random-string

# --- styled mode (curated look with your streams) ---
# native = provider categories as-is; ganja = styled from a curated template
#PLAYLIST_STYLE=ganja
# EPGenius playlist number from epgenius.org "Choose a Playlist"
#TEMPLATE_ID=6
# Or any plain M3U url instead of the EPGenius API:
#TEMPLATE_URL=https://example.com/template.m3u
#TEMPLATE_EPG_URL=https://example.com/guide.xml.gz
# Public URL of THIS server, used for the playlist's built-in guide link:
#PUBLIC_BASE_URL=https://playlist.example.com

# --- quality and backup sources ---
#MULTI_STREAM=on
#MULTI_STREAM_MAX=3
#QUALITY_CAP=fhd
#STREAM_EXT=ts

# --- freshness ---
#REFRESH_HOURS=24
#RELOAD_REFRESH_MINUTES=15
#RELOAD_WAIT_SECONDS=8
#EPG_MERGE=on
#EPG_REFRESH_HOURS=24

# --- category selection (all default to "keep everything") ---
# Prefixes before the provider's "❖" group separator, in display order:
#INCLUDE_REGIONS=US,VIP,UK,CA,AU,NZ,CAR,ALL
# Exact category names to skip:
#EXCLUDE_GROUPS=CA ❖ QUEBEC,VIP ❖ FIFA WC26 ES
# Per-region whitelist (keep only these from an included region):
#ONLY_GROUPS=CAR ❖ CARIBBEAN
